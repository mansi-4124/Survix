generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum AuthType {
  LOCAL
  GOOGLE
  BOTH
}

enum OrganizationVisibility {
  PUBLIC
  PRIVATE
}

enum OrganizationStatus {
  ACTIVE
  ARCHIVED
  SUSPENDED
}

enum OrganizationAccountType {
  PERSONAL
  ORGANIZATION
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum OrganizationMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
  LEFT
}

enum SurveyStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  CLOSED
}

enum SurveyVisibility {
  PUBLIC
  PRIVATE
}

enum SurveyRole {
  OWNER
  ADMIN
  EDITOR
  ANALYST
  VIEWER
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  CHECKBOX
  RADIO
  RATING
  DATE
  FILE_UPLOAD
  AUDIO
  VIDEO
  RANKING
}

enum MediaType {
  IMAGE
  AUDIO
  VIDEO
  FILE
}

enum ResponseStatus {
  COMPLETED
  PARTIAL
}

enum PollType {
  MCQ
  ONE_WORD
}

enum PollStatus {
  DRAFT
  LIVE
  CLOSED
}

//////////////////////////////////////////////////////
// AUTH MODULE
//////////////////////////////////////////////////////

model User {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  email         String     @unique
  username      String?    @unique
  passwordHash  String?
  name          String?
  avatar        String?
  emailVerified Boolean?
  authType      AuthType
  googleId      String?    @unique
  status        UserStatus @default(ACTIVE)

  failedLoginAttempts  Int      @default(0)
  lockUntil            DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passwordHistory PasswordHistory[]
  organizations   OrganizationMember[]
  surveyMembers   SurveyMember[]
  responses       Response[]
  sessions        Session[]
  pollsCreated    Poll[]
}

model PasswordHistory {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  passwordHash String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  sessionId        String @id @default(uuid()) @map("_id")
  userId           String    @db.ObjectId
  refreshTokenHash String
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?

  userAgent        String?
  ipAddress        String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

//////////////////////////////////////////////////////
// ORGANIZATION MODULE
//////////////////////////////////////////////////////

model Organization {
  id           String                 @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String                 @unique
  logoUrl      String?
  ownerId      String                 @db.ObjectId
  accountType  OrganizationAccountType @default(ORGANIZATION)
  isPersonal   Boolean                @default(false)
  description  String?
  industry     String?
  size         String?
  websiteUrl   String?
  contactEmail String?
  visibility   OrganizationVisibility
  status       OrganizationStatus
  deletedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members OrganizationMember[]
  surveys Survey[]
  polls   Poll[]

  @@index([ownerId])
  @@index([status])
}

model OrganizationMember {
  id             String                   @id @default(auto()) @map("_id") @db.ObjectId
  organizationId String                   @db.ObjectId
  userId         String                   @db.ObjectId
  role           OrganizationRole
  status         OrganizationMemberStatus

  joinedAt  DateTime?
  leftAt    DateTime?
  invitedBy String?   @db.ObjectId
  removedBy String?   @db.ObjectId

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

//////////////////////////////////////////////////////
// SURVEY MODULE
//////////////////////////////////////////////////////

model Survey {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?

  organizationId String? @db.ObjectId
  ownerUserId    String? @db.ObjectId

  status         SurveyStatus
  visibility     SurveyVisibility
  allowAnonymous Boolean
  allowMultipleResponses Boolean @default(false)
  randomizeQuestions Boolean
  revision       Int              @default(1)

  startDate       DateTime?
  endDate         DateTime?
  publishedAt     DateTime?
  resultPublished Boolean   @default(false)

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization?  @relation(fields: [organizationId], references: [id])
  pages        SurveyPage[]
  members      SurveyMember[]
  responses    Response[]
  mediaAssets  MediaAsset[]

  @@index([organizationId])
  @@index([ownerUserId])
  @@index([status])
  @@index([visibility, status])
  @@index([startDate])
  @@index([endDate])
}

model SurveyPage {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  surveyId    String  @db.ObjectId
  createdBy   String  @db.ObjectId
  title       String
  description String?
  order       Int

  survey    Survey     @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  questions Question[]

  @@index([surveyId])
}

model SurveyMember {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  surveyId   String     @db.ObjectId
  userId     String     @db.ObjectId
  role       SurveyRole
  assignedBy String?    @db.ObjectId
  assignedAt DateTime   @default(now())
  removedAt  DateTime?

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
  @@index([surveyId])
  @@index([userId])
}

//////////////////////////////////////////////////////
// QUESTION MODULE
//////////////////////////////////////////////////////

model Question {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  pageId           String       @db.ObjectId
  text             String
  description      String?
  type             QuestionType
  isRequired       Boolean
  randomizeOptions Boolean
  order            Int
  settings         Json?
  mediaAssetId     String?      @db.ObjectId
  createdBy        String       @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page    SurveyPage       @relation(fields: [pageId], references: [id], onDelete: Cascade)
  options QuestionOption[]
  answers Answer[]

  @@index([pageId])
  @@index([pageId, order])
  @@index([mediaAssetId])
}

model QuestionOption {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  questionId   String  @db.ObjectId
  createdBy    String  @db.ObjectId
  label        String
  value        String
  order        Int
  mediaAssetId String? @db.ObjectId

  createdAt DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, value])
  @@index([questionId])
}

//////////////////////////////////////////////////////
// MEDIA MODULE
//////////////////////////////////////////////////////

model MediaAsset {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  ownerId    String    @db.ObjectId
  surveyId   String?   @db.ObjectId
  type       MediaType
  url        String
  storageKey String
  mimeType   String
  size       Int
  width      Int?
  height     Int?
  duration   Int?

  createdAt DateTime @default(now())

  survey Survey? @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([surveyId])
  @@index([ownerId, surveyId])
}

//////////////////////////////////////////////////////
// RESPONSE MODULE
//////////////////////////////////////////////////////

model Response {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  surveyId       String         @db.ObjectId
  userId         String?        @db.ObjectId
  anonymousId    String?
  submittedAt    DateTime?
  completionTime Int?
  ipAddress      String?
  userAgent      String?
  status         ResponseStatus

  createdAt DateTime @default(now())

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  answers Answer[]

  @@index([surveyId])
  @@index([surveyId, status])
  @@index([userId])
}

model Answer {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  responseId String   @db.ObjectId
  questionId String   @db.ObjectId
  value      Json
  createdAt  DateTime @default(now())

  response Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@index([responseId])
  @@index([questionId])
}

//////////////////////////////////////////////////////
// POLL MODULE
//////////////////////////////////////////////////////

model Poll {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  code           String   @unique
  organizationId String   @db.ObjectId
  title          String
  description    String?
  createdBy      String   @db.ObjectId
  status         PollStatus @default(DRAFT)
  startsAt       DateTime @default(now())
  expiresAt      DateTime
  allowAnonymous     Boolean @default(true)
  allowMultipleVotes Boolean @default(false)
  showLiveResults    Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  questions    PollQuestion[]
  votes        PollVote[]

  @@index([organizationId])
  @@index([createdBy])
  @@index([status])
  @@index([expiresAt])
  @@index([organizationId, createdAt])
}

model PollQuestion {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  pollId    String   @db.ObjectId
  text      String
  type      PollType
  order     Int
  createdAt DateTime @default(now())

  poll    Poll               @relation(fields: [pollId], references: [id], onDelete: Cascade)
  options PollQuestionOption[]
  votes   PollVote[]

  @@index([pollId])
  @@index([pollId, order])
}

model PollQuestionOption {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  questionId String   @db.ObjectId
  text       String
  createdAt  DateTime @default(now())

  question PollQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model PollVote {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  pollId     String   @db.ObjectId
  questionId String   @db.ObjectId
  optionId   String?  @db.ObjectId
  wordAnswer String?
  userId     String?  @db.ObjectId
  sessionId  String?
  voterKey   String
  participantName String?
  createdAt  DateTime @default(now())

  poll     Poll         @relation(fields: [pollId], references: [id], onDelete: Cascade)
  question PollQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([pollId])
  @@index([questionId])
  @@index([optionId])
  @@index([userId])
  @@index([sessionId])
  @@index([voterKey])
  @@index([pollId, createdAt])
  @@unique([pollId, questionId, voterKey])
}

model PollAnalytics {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  pollId     String   @db.ObjectId
  totalVotes Int
  totalViewers Int
  peakVotesPerMinute Int
  createdAt  DateTime @default(now())

  @@index([pollId])
}

model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  action    String
  entity    String
  entityId  String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityId])
}

model PollParticipant {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  pollId    String   @db.ObjectId
  userId    String?  @db.ObjectId
  sessionId String?
  joinedAt  DateTime @default(now())

  @@index([pollId])
}
