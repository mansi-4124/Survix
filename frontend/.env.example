# API base URL. Use empty string ("") in development when using Vite proxy.
# In production, set to your backend URL (e.g. https://api.example.com).
VITE_API_BASE_URL=

# Google OAuth client ID for sign-in. Optional; omit to hide Google login.
VITE_GOOGLE_CLIENT_ID=

# WebSocket base URL for real-time features (polls). Defaults to API base in production.
# In dev with proxy, use empty string or same as API.
VITE_SOCKET_BASE_URL=
